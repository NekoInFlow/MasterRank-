# Supabase project URL (HTTPS)
# Dashboard → Settings → API → Project URL — обычно https://xxxx.supabase.co
#
# Если из браузера напрямую *.supabase.co недоступен (например в РФ):
# подставь сюда URL своего прокси, например на Vercel:
# https://your-domain.vercel.app/api/supabase
# ключ anon при этом не менять.
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon (public) key — safe to expose in frontend
# Dashboard → Settings → API → Project API keys → anon / public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional for Vercel proxy fallback (server-side):
# set this in Vercel Project Settings -> Environment Variables
# SUPABASE_ANON_KEY=your-anon-key-here
